# 数据库配置
DATABASE_URL="postgresql://user:password@localhost:5432/dbname"
POSTGRES_URL="postgresql://user:password@localhost:5432/dbname"

# AI 配置
OPENAI_API_KEY="your_openai_api_key_here"
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL="gpt-3.5-turbo"

# AI Prompt 配置（可选）
AI_SYSTEM_PROMPT="你是一个专业的技术新闻翻译和摘要助手，擅长将英文技术新闻翻译成准确、流畅的中文。"
AI_USER_PROMPT_TEMPLATE="请为以下技术新闻生成中文标题和摘要：\n\n【原标题】{title}\n{url_info}\n\n请按以下格式回复：\n中文标题：[一个吸引人的中文标题，不超过50字]\n摘要：[用2-3句话总结文章亮点，突出技术价值和实用性，不超过100字]"
AI_USER_PROMPT_TEMPLATE_WITH_CONTENT="请基于以下完整的技术文章内容生成准确的中文标题和摘要：\n\n【原标题】{title}\n【文章网址】{url}\n【文章内容】\n{content}\n\n请按以下格式回复：\n中文标题：[基于实际内容的准确中文标题，不超过50字]\n摘要：[基于完整内容的详细摘要，突出核心观点和技术要点，100-150字]"

# 队列配置（可选）
QUEUE_CONCURRENCY=3
QUEUE_RETRY_ATTEMPTS=3
QUEUE_RETRY_DELAY=5000

# 内容抓取配置（可选）
CONTENT_FETCH_ENABLED=true
CONTENT_MAX_LENGTH=10000
CONTENT_TIMEOUT=30000

# 日志配置
LOG_LEVEL="info"
LOGS_DIR="./logs"

# 应用配置
NEXT_PUBLIC_APP_URL="https://your-domain.com"
NODE_ENV="development"

# 分析工具配置（可选）
NEXT_PUBLIC_UMAMI_SCRIPT_URL="https://cloud.umami.is/script.js"
NEXT_PUBLIC_UMAMI_WEBSITE_ID="your_umami_website_id_here"

# WebSocket 配置（可选）
WEBSOCKET_ENABLED=true
WEBSOCKET_CORS_ORIGIN="http://localhost:3000"
WEBSOCKET_PING_TIMEOUT=60000
WEBSOCKET_PING_INTERVAL=25000
# 管理端点鉴权（/api/db/init、/api/logs、/api/queue/status POST 需携带
# Authorization: Bearer <secret> 或 x-admin-secret 头；不设置则这些端点禁用）
ADMIN_SECRET="change-me"

# 翻译结果缓存时长（小时，默认 168 = 7 天；翻译内容不可变，无需频繁过期）
CACHE_TTL_HOURS=168

# 送入 LLM 的正文最大字符数（默认 8000，防止超出小上下文模型限制）
AI_MAX_CONTENT_CHARS=8000

# processing 状态超时回收阈值（分钟，默认 10）
QUEUE_STUCK_TIMEOUT_MINUTES=10

# 写文件日志（默认 false，容器环境用 stdout；置 true 需挂载可写 LOGS_DIR）
LOG_TO_FILES=false

# 禁用进程内队列 worker（默认启用；仅在单独跑 worker 进程时置 true）
DISABLE_QUEUE_WORKER=false

# 无头 Chrome 抓取（可选，参考 karakeep 架构；不配置则退回 axios 直抓）
CHROME_CDP_URL="http://chrome.karakeep:9222"

# 火山方舟推理模型关闭 thinking（避免隐藏推理烧 tokens）
AI_THINKING="disabled"

# FlareSolverr 反检测抓取服务（可选，优先级高于 CHROME_CDP_URL；过 Cloudflare 等 JS 挑战墙）
FLARESOLVERR_URL="http://xhn-flaresolverr:8191"

# ladder 付费墙代理（可选，抓取链第二级；处理付费墙/cookie墙）
LADDER_URL="http://xhn-ladder:8080"
# 抓不到正文时的摘要提示语
AI_FETCH_FAILED_MESSAGE="⚠️ 无法抓取正文内容（可能是反爬限制、付费墙或需要登录），请点击原文查看。"
